<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE suite SYSTEM "https://testng.org/testng-1.0.dtd">
<suite name="Notes App BDD Suite" parallel="none">
    <test name="Parallel UI and API Tests" parallel="classes" thread-count="2">
        <classes>
            <class name="com.practice.notes.runner.UiTestRunner"/>
            <class name="com.practice.notes.runner.ApiTestRunner"/>
        </classes>
    </test>
    <test name="Serial E2E Tests">
        <classes>
            <class name="com.practice.notes.runner.E2eTestRunner"/>
        </classes>
    </test>
</suite>
