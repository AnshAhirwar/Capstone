[
  {
    "command": "navigate",
    "params": {
      "url": "https://practice.expandtesting.com/notes/app/login"
    }
  },
  {
    "command": "type",
    "params": {
      "id": "email",
      "text": "ansh@gmail.com",
      "fallbacks": [
        { "name": "email" },
        { "css": "input[type='email']" }
      ]
    }
  },
  {
    "command": "type",
    "params": {
      "id": "password",
      "text": "12345678",
      "fallbacks": [
        { "name": "password" },
        { "css": "input[type='password']" }
      ]
    }
  },
  {
    "command": "click",
    "params": {
      "css": "button[type='submit']",
      "fallbacks": [
        { "testid": "login-submit" },
        { "xpath": "//button[contains(text(),'Login')]" }
      ]
    }
  },
  {
    "command": "assert_text",
    "params": {
      "text": "Notes"
    }
  },
  {
    "command": "screenshot",
    "params": {}
  },
  {
    "command": "click",
    "params": {
      "testid": "add-new-note",
      "fallbacks": [
        { "css": "[data-testid='add-new-note']" },
        { "xpath": "//button[contains(text(),'Add Note')]" }
      ]
    }
  },
  {
    "command": "type",
    "params": {
      "id": "title",
      "text": "MCP Generated Note"
    }
  },
  {
    "command": "type",
    "params": {
      "id": "description",
      "text": "This note was created by the MCP Selenium Bridge"
    }
  },
  {
    "command": "click",
    "params": {
      "testid": "note-submit",
      "fallbacks": [
        { "css": "[data-testid='note-submit']" },
        { "xpath": "//button[contains(text(),'Save')]" }
      ]
    }
  },
  {
    "command": "assert_text",
    "params": {
      "text": "MCP Generated Note"
    }
  },
  {
    "command": "screenshot",
    "params": {}
  },
  {
    "command": "get_page_source",
    "params": {}
  }
]
